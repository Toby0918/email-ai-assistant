# Backend-only local configuration example.
# Copy this file to .env for local development. Do not commit .env.

OPENAI_API_KEY=your_api_key_here
DEEPSEEK_API_KEY=

EMAIL_AGENT_SQLITE_PATH=outputs/email_agent.sqlite3
EMAIL_AGENT_LOG_LEVEL=INFO

# Optional backend-only local model provider.
# Keep disabled unless you intentionally want the Python backend to call local Ollama.
EMAIL_AGENT_LLM_PROVIDER=disabled
EMAIL_AGENT_OLLAMA_BASE_URL=http://127.0.0.1:11434
EMAIL_AGENT_OLLAMA_MODEL=qwen3.6:latest
EMAIL_AGENT_OLLAMA_TIMEOUT_SECONDS=30

# Optional backend-only DeepSeek provider settings. The provider remains disabled by default.
EMAIL_AGENT_DEEPSEEK_MODEL=deepseek-v4-flash
EMAIL_AGENT_DEEPSEEK_TIMEOUT_SECONDS=10
EMAIL_AGENT_DEEPSEEK_OUTPUT_MODE=conservative

# Phase-two attachment-analysis limits. Files are handled by the backend only.
EMAIL_AGENT_ATTACHMENT_TEMP_DIR=outputs/attachment_temp
EMAIL_AGENT_ATTACHMENT_RETENTION_HOURS=24
EMAIL_AGENT_ATTACHMENT_MAX_FILES=5
EMAIL_AGENT_ATTACHMENT_MAX_FILE_BYTES=10485760
EMAIL_AGENT_ATTACHMENT_MAX_TOTAL_BYTES=26214400
EMAIL_AGENT_INTERNAL_EMAIL_DOMAINS=cndlf.com

# Phase-two boundary:
# - Only an explicit Analyze click may transfer resources visibly associated with the current message.
# - Attachment bytes are validated and parsed by the backend only; they are never stored in SQLite.
# - Do not connect a real mailbox account unless separately confirmed.
# - Do not put OpenAI/Ollama model credentials or model calls in frontend code.
# - Do not auto-send, delete, or archive emails.
