{
  "manifest_version": 3,
  "name": "Email AI Assistant for Tencent Exmail",
  "description": "Analyze the currently opened Tencent Exmail message through the local Email AI Assistant backend.",
  "version": "0.2.3",
  "action": {
    "default_title": "Email AI Assistant"
  },
  "permissions": ["activeTab", "sidePanel"],
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "host_permissions": [
    "https://exmail.qq.com/*",
    "http://127.0.0.1:8765/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://exmail.qq.com/*"],
      "js": [
        "content/exmail_visible_context.js",
        "content/exmail_visible_resource_classifier.js",
        "content/current_message_collector.js",
        "content/exmail_adapter.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
